# .env file will be created here

# GitHub 配置
GITHUB_TOKEN=your_github_token_here

# AI API 密钥配置

# Anthropic API (用于 Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 千问 API (阿里云 DashScope)
QWEN_API_KEY=your_qwen_api_key_here

# 豆包 API (字节跳动)
DOUBAO_API_KEY=your_doubao_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# 自定义 API
CUSTOM_API_KEY=your_custom_api_key_here

# AI 模型设置

# 提供商类型：anthropic, openai, qwen, doubao, custom
AI_PROVIDER=anthropic

# 模型名称 (根据 provider 调整)
# anthropic: claude-sonnet-4-20250929, claude-3-5-sonnet-20241022
# openai: gpt-4o, gpt-4o-mini
# qwen: qwen-max, qwen-plus
# doubao: deepseek-v3
AI_MODEL=claude-sonnet-4-20250929

# 自定义 API URL (仅当 provider=custom 时使用)
# AI_BASE_URL=https://your-custom-api.com/v1/chat/completions
